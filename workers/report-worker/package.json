{
  "name": "@edutrack/report-worker",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "description": "Async report generation worker",
  "scripts": {
    "build": "node ../../scripts/run-tsc.mjs -p tsconfig.build.json",
    "dev": "node ../../scripts/run-tsc.mjs -p tsconfig.build.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "node ../../scripts/run-tsc.mjs -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@edutrack/logging": "workspace:*",
    "@edutrack/config": "workspace:*",
    "@edutrack/shared": "workspace:*"
  },
  "devDependencies": {
    "@edutrack/eslint-config": "workspace:*",
    "@edutrack/jest-config": "workspace:*",
    "@edutrack/typescript-config": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
