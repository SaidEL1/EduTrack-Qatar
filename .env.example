# EduTrack environment template — copy to .env.local (never commit secrets)
# @see docs/engineering/SECRETS_MANAGEMENT.md

NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=edutrack-api
PORT=3000
HOST=0.0.0.0
API_PREFIX=v1
OTEL_ENABLED=true
METRICS_PORT=9464

# Database (Docker Compose defaults — required for API)
DATABASE_URL=postgresql://edutrack:edutrack_local_dev@localhost:5432/edutrack

# Redis (Docker Compose defaults)
REDIS_URL=redis://localhost:6379

# Secrets — prefix with EDUTRACK_ for SecretsProvider
# EDUTRACK_JWT_PRIVATE_KEY=
# EDUTRACK_JWT_PUBLIC_KEY=

# API base URL for portal clients (Sprint 1+)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
